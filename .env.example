# Пример конфигурации
# Скопируйте в .env и измените значения

# Database
DATABASE_URL=postgresql+asyncpg://civs_user:civs_password@localhost:5432/civs_db
AUTO_INIT_DB=false

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Crypto
SIGNATURE_ALGORITHM=Ed25519
HASH_ALGORITHM=SHA256

# Trust Score
TRUST_THRESHOLD_ACCEPT=0.7
TRUST_THRESHOLD_QUARANTINE=0.4

# Security
REPLAY_WINDOW_SECONDS=30

# OpenAI live demo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_OUTPUT_TOKENS=160
